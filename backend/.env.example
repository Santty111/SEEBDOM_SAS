PORT=5000
# MongoDB Atlas (recomendado) o URI local con replica set si usas mongod con --replSet.
# Sustituye USUARIO, CONTRASENA (URL-encode si tiene @ # etc.) y el host del clúster en Atlas.
MONGODB_URI=mongodb+srv://USUARIO:CONTRASENA@cluster0.xxxxx.mongodb.net/sebdom?retryWrites=true&w=majority
JWT_SECRET=STRING_ALEATORIA_LARGA
JWT_EXPIRES_IN=7d
# Orígenes permitidos (frontend Vercel, Vite local). Separados por coma. Vacío o * = refleja el origen en desarrollo.
CORS_ORIGINS=http://localhost:5173,https://tu-app.vercel.app
# Si es "true", se desactiva POST /api/auth/register (solo login).
DISABLE_REGISTRATION=false
