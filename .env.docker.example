# Copiar a .env en la raíz del repo antes de `docker compose up` (setup.sh lo hace si no existe).
# Nunca subas .env al repositorio.

# --- MongoDB (obligatorio para Docker) ---
# Atlas: Connect → Drivers → Node.js. Pega aquí la URI completa (una línea). Si la contraseña tiene caracteres especiales, URL-encódala.
MONGODB_URI=

# Obligatorio: secreto largo y aleatorio (p. ej. en PowerShell: [Convert]::ToHexString((1..32|%{Get-Random -Max 256})))
JWT_SECRET=definir_secreto_jwt_largo_y_aleatorio

# Orígenes del frontend (separados por coma). Incluye IP de la Torre/LAN si sirves el build estático.
# Ejemplo: http://localhost:5173,http://192.168.1.50:4173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_EXPIRES_IN=7d
DISABLE_REGISTRATION=false
