# Copiar a .env en la raíz del repo antes de `docker compose up` (setup.sh lo hace si no existe).
# Nunca subas .env al repositorio.

# Obligatorio en producción: cadena larga y aleatoria (p. ej. openssl rand -hex 32)
JWT_SECRET=cambiar_por_secreto_largo_y_aleatorio

# Orígenes del frontend (separados por coma). Incluye IP de la Torre/LAN si sirves el build estático.
# Ejemplo: http://localhost:5173,http://192.168.1.50:4173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_EXPIRES_IN=7d
DISABLE_REGISTRATION=false
