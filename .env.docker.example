# Copiar a .env en la raíz del repo antes de `docker compose up` (setup.sh lo hace si no existe).
# Nunca subas .env al repositorio.

# --- MongoDB (obligatorio para Docker) ---
# MongoDB Atlas: Connect → Drivers → Node.js. Sustituye usuario, contraseña (URL-encode si tiene @ # etc.) y host.
MONGODB_URI=mongodb+srv://USUARIO:CONTRASENA@cluster0.xxxxx.mongodb.net/sebdom?retryWrites=true&w=majority

# Obligatorio en producción: cadena larga y aleatoria (p. ej. openssl rand -hex 32)
JWT_SECRET=4f9e6b2d8a1c5b3e7f0d9a2c4b6e8f1a0d3c5e7b9a2f4d6b8e1c3a5f7d90b2e4

# Orígenes del frontend (separados por coma). Incluye IP de la Torre/LAN si sirves el build estático.
# Ejemplo: http://localhost:5173,http://192.168.1.50:4173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_EXPIRES_IN=7d
DISABLE_REGISTRATION=false
